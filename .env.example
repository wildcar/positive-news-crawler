NEWSAGG_SECRET_KEY=replace-with-at-least-50-random-characters
NEWSAGG_DB_PATH=./data/newsagg.sqlite3
NEWSAGG_BACKUP_DIR=./data/backups
NEWSAGG_LOG_DIR=./data/logs
NEWSAGG_ALLOWED_HOSTS=127.0.0.1,localhost
NEWSAGG_USER_AGENT=PositiveNewsAggregator/0.1 (+mailto:operator@example.com)
NEWSAGG_DEBUG=0
# Set all four to 1 only when HTTPS is configured:
NEWSAGG_SECURE=0

