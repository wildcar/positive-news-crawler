NEWSCRAWLER_SECRET_KEY=replace-with-at-least-50-random-characters
NEWSCRAWLER_DB_PATH=./data/newscrawler.sqlite3
NEWSCRAWLER_BACKUP_DIR=./data/backups
NEWSCRAWLER_LOG_DIR=./data/logs
NEWSCRAWLER_ALLOWED_HOSTS=127.0.0.1,localhost
NEWSCRAWLER_CSRF_TRUSTED_ORIGINS=
NEWSCRAWLER_USER_AGENT="PositiveNewsCrawler/0.1 (+mailto:operator@example.com)"
NEWSCRAWLER_DEBUG=0
NEWSCRAWLER_LOG_LEVEL=INFO
# Set all four to 1 only when HTTPS is configured:
NEWSCRAWLER_SECURE=0
NEWSCRAWLER_ROUTER_MCP_URL=http://127.0.0.1:8088/mcp
NEWSCRAWLER_ROUTER_AUTH_TOKEN=fill-me
NEWSCRAWLER_ROUTER_TIMEOUT_SECONDS=300
NEWSCRAWLER_TRANSLATION_PROVIDER=deepseek
NEWSCRAWLER_TRANSLATION_MODEL=deepseek-chat
NEWSCRAWLER_TRANSLATION_TIER=
NEWSCRAWLER_TRANSLATION_TEMPERATURE=0.2
NEWSCRAWLER_TRANSLATION_MAX_TOKENS=8192
NEWSCRAWLER_MANUAL_SCORE_SELECTOR=news-evaluator
