NEWSCRAWLER_SECRET_KEY=replace-with-at-least-50-random-characters
NEWSCRAWLER_DB_PATH=/var/lib/newscrawler/newscrawler.sqlite3
NEWSCRAWLER_BACKUP_DIR=/var/lib/newscrawler/backups
NEWSCRAWLER_LOG_DIR=/var/log/newscrawler
NEWSCRAWLER_ALLOWED_HOSTS=127.0.0.1,localhost
NEWSCRAWLER_CSRF_TRUSTED_ORIGINS=
NEWSCRAWLER_USER_AGENT="PositiveNewsCrawler/0.1 (+mailto:operator@example.com)"
NEWSCRAWLER_DEBUG=0
NEWSCRAWLER_LOG_LEVEL=INFO
NEWSCRAWLER_SECURE=0
PLAYWRIGHT_BROWSERS_PATH=/var/lib/newscrawler/playwright
