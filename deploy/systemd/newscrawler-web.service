[Unit]
Description=Positive News Crawler web UI
After=network.target model-router-mcp.service
ConditionPathExists=/etc/newscrawler/newscrawler.env
ConditionPathExists=/var/lib/newscrawler/newscrawler.sqlite3
ConditionPathIsDirectory=/var/lib/newscrawler

[Service]
Type=simple
User=newscrawler
Group=newscrawler
WorkingDirectory=/opt/newscrawler
EnvironmentFile=/etc/newscrawler/newscrawler.env
Environment=PYTHONDONTWRITEBYTECODE=1
UMask=0007
ExecStartPre=/usr/bin/chmod 0660 /var/lib/newscrawler/newscrawler.sqlite3
ExecStart=/opt/newscrawler/.venv/bin/python -m waitress --listen=127.0.0.1:8000 --trusted-proxy=127.0.0.1 --trusted-proxy-headers=x-forwarded-proto newscrawler.wsgi:application
Restart=always
RestartSec=5
PrivateTmp=true
NoNewPrivileges=true
ProtectSystem=strict
ReadWritePaths=/var/lib/newscrawler /var/log/newscrawler

[Install]
WantedBy=multi-user.target
